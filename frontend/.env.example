# Copy to `.env.local` and fill in real values. Never commit `.env.local`.

# NVIDIA NIM (Kimi K2)
NVIDIA_API_KEY=

# AWS Bedrock (Claude Sonnet 4.6)
AWS_BEARER_TOKEN_BEDROCK=
AWS_REGION=us-east-1

# Vertex AI (Gemini 3.1 Pro Preview) - read by both the frontend
# /api/race route and pipeline/multi_model_study.py.
CLOUD_RUN_API_KEY=
GEMINI_VERTEX_MODEL=gemini-3.1-pro-preview

# Optional: standard Gemini API key, used only by the smoke test
# pipeline/test_api_endpoints.py.
GEMINI_API_KEY=
