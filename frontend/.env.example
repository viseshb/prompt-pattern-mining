# Copy to `.env.local` and fill in real values. Never commit `.env.local`.

# Token that authenticates Kimi K2.5, Claude Sonnet 4.6, and
# Claude Haiku 4.5. One value covers all three.
AWS_BEARER_TOKEN_BEDROCK=
AWS_REGION=us-east-1

# Gemini 3.1 Pro Preview (used by both the frontend race demo and
# pipeline/multi_model_study.py).
CLOUD_RUN_API_KEY=
GEMINI_VERTEX_MODEL=gemini-3.1-pro-preview

# Optional: standard Gemini API key, used only by the smoke test
# pipeline/test_api_endpoints.py.
GEMINI_API_KEY=
