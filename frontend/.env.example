# Copy to `.env.local` and fill in real values. Never commit `.env.local`.

# NVIDIA NIM (Kimi K2)
NVIDIA_API_KEY=

# AWS Bedrock (Claude Sonnet 4.6)
AWS_BEARER_TOKEN_BEDROCK=
AWS_REGION=us-east-1

# Google Vertex AI (Gemini 3.1 Pro Preview)
GEMINI_VERTEX_PROJECT=
GEMINI_VERTEX_REGION=us-central1
GEMINI_VERTEX_MODEL=gemini-3.1-pro-preview

# Optional: standard Gemini API (used by smoke test)
GEMINI_API_KEY=

# Optional: Cloud Run-hosted Gemini key (used by pipeline/test_api_endpoints.py)
CLOUDRUN_API_KEY=
